---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
}

const {
  title,
  description = 'Handcrafted guitars made by Vibrum — where traditional craftsmanship meets design. Unique, high-quality instruments built in Belgrade, Serbia.',
  ogImage = '/images/og-logo.png',
  ogType = 'website',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0a0906" />
    <script is:inline>
      if (!sessionStorage.getItem('splashSeen')) {
        sessionStorage.setItem('splashSeen', '1');
        document.documentElement.classList.add('splash-show');
      }
    </script>

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Vibrum Guitars" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Favicons -->
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon/favicon-48.png" />
    <link rel="apple-touch-icon" href="/favicon/apple-touch-icon.png" />
    <link rel="manifest" href="/favicon/site.webmanifest" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600&family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=Roboto:wght@400;700&display=swap"
      rel="stylesheet"
    />

    <slot name="head" />
  </head>

  <style is:global>
    .splash {
      display: none;
    }

    .splash-show .splash {
      position: fixed;
      inset: 0;
      z-index: 1000;
      display: flex;
      align-items: center;
      justify-content: center;
      padding-top: 8vh;
      background: var(--color-bg);
      animation: splash-out 1.1s ease-in 1.0s forwards;
    }

    .splash-show .splash svg {
      width: min(88vw, 88vh);
      height: auto;
      animation: splash-logo-in 0.7s ease-out both;
    }

    @keyframes splash-logo-in {
      from { opacity: 0; transform: scale(0.94); }
      to   { opacity: 1; transform: scale(1); }
    }

    @keyframes splash-out {
      from { opacity: 1; }
      to   { opacity: 0; }
    }

    @media (prefers-reduced-motion: reduce) {
      .splash-show .splash { display: none; }
    }
  </style>
  <body>
    <div class="splash" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 320 320" aria-hidden="true" focusable="false">
        <defs>
          <style>
            .logo-d { letter-spacing: .213em; }
            .logo-e { letter-spacing: .217em; }
            .logo-f { letter-spacing: .213em; }
            .logo-g { font-family: 'TERMINAT', Terminator, serif; font-size: 27.486px; }
            .logo-g, .logo-h { fill: #d8d4c0; }
            .logo-i { letter-spacing: .212em; }
            .logo-j { letter-spacing: .211em; }
          </style>
        </defs>
        <path class="logo-h" d="m157,41v111.958c0,.179-.095.344-.25.433l-96.939,55.98c-.443.256-.939-.24-.683-.683L156.067,40.75c.256-.443.933-.262.933.25Z"/>
        <path class="logo-h" d="m163,152.958V40.999c0-.512.677-.693.933-.25l96.939,167.938c.256.443-.24.939-.683.683l-96.939-55.98c-.155-.089-.25-.254-.25-.433Z"/>
        <path class="logo-h" d="m62.809,214.567l96.941-55.98c.155-.089.345-.089.5,0l96.94,55.98c.443.256.261.933-.25.933H63.059c-.512,0-.693-.677-.25-.933Z"/>
        <text class="logo-g" transform="translate(62.698 243.05)"><tspan class="logo-f" x="0" y="0">V</tspan><tspan class="logo-e" x="35.853" y="0">I</tspan><tspan class="logo-j" x="50.063" y="0">BR</tspan><tspan class="logo-i" x="124.43" y="0">U</tspan><tspan class="logo-d" x="161.962" y="0">M</tspan></text>
      </svg>
    </div>
    <slot />
  </body>
  <script>
    const splash = document.querySelector('.splash') as HTMLElement | null;
    if (splash) {
      splash.addEventListener('animationend', (e) => {
        if ((e as AnimationEvent).animationName === 'splash-out') {
          splash.style.display = 'none';
        }
      });
    }
  </script>
</html>
