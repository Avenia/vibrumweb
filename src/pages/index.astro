---
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';
import StoryCard from '../components/StoryCard.astro';

const stories = (await getCollection('stories', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

  // TODO: move slideshow to a separate component and fetch images from a folder or CMS instead of hardcoding
const slides = [
  { src: '/images/guitars/pyrocaster/pyrocaster.webp', text: 'Handcrafted in Belgrade\nWith passion.\nWith precision.\nWith Bla Bla bla' },
  { src: '/images/slideshow/Screenshot 2026-03-30 at 22-35-44 Instagram.png', text: 'Built to last a lifetime' },
  { src: '/images/slideshow/Screenshot 2026-03-30 at 22-35-55 Instagram.png', text: 'Every detail considered' },
  // { src: '/images/slideshow/Screenshot 2026-03-30 at 22-36-04 Instagram.png'},
  // // { src: '/images/slideshow/Screenshot 2026-03-30 at 22-36-21 Instagram.png', text: 'From the workshop' },
  // // { src: '/images/slideshow/Screenshot 2026-03-30 at 22-36-35 Instagram.png', text: 'Traditional meets design' },
  // // { src: '/images/slideshow/Screenshot 2026-03-30 at 22-36-48 Instagram.png', text: 'Unique instruments' },
];
---

<PageLayout
  title="Vibrum | Handcrafted guitars"
  description="Handcrafted guitars made by Vibrum, where traditional craftsmanship meets design. We are dedicated to creating unique, high-quality instruments that inspire musicians worldwide."
>
  <div class="container section">
    <div class="slideshow" id="slideshow" aria-label="Workshop slideshow">
      {slides.map((slide, i) => (
        <div class={`slide${i === 0 ? ' active' : ''}`} data-index={i}>
          <img src={slide.src} alt="" loading={i === 0 ? 'eager' : 'lazy'} />
        </div>
      ))}

      <div class="typewriter-overlay">
        <!-- <p class="tw-eyebrow">Vibrum Guitars</p> TODO: maybe add this to upper left corner as a static element, but make support to define in slides -->
        <!-- <p class="tw-text"><span id="tw-target"></span><span class="tw-cursor">|</span></p> -->
        <p class="tw-text"><span id="tw-target"></span></p>
      </div>
      <button class="slide-arrow slide-prev" aria-label="Previous slide">&#8592;</button>
      <button class="slide-arrow slide-next" aria-label="Next slide">&#8594;</button>
      <div class="slide-dots" id="slide-dots">
        {slides.map((_, i) => (
          <button class={`slide-dot${i === 0 ? ' active' : ''}`} data-dot={i} aria-label={`Go to slide ${i + 1}`}></button>
        ))}
      </div>
    </div>

<!-- SLIDE SHOW ABOVE -->
<!-- STORIES BELOW -->

    <header class="home-header">
      <p class="home-eyebrow">From the workshop</p>
      <h1 class="home-title">Check out our latest stories</h1>
      <p class="home-subtitle">
        Each build has a story. Follow the work — new instruments, materials, and ideas from Belgrade.
      </p>
    </header>

    {stories.length > 0 ? (
      <div class="stories-grid">
        {stories.map(story => (
          <StoryCard
            title={story.data.title}
            slug={story.slug}
            date={story.data.date}
            coverImage={story.data.coverImage}
            excerpt={story.data.excerpt}
            tags={story.data.tags}
          />
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <p>Stories coming soon. Check back after the first build.</p>
        <a href="/gallery" class="empty-cta">Browse the gallery →</a>
      </div>
    )}
  </div>
</PageLayout>

<style>
  .home-header {
    margin-top: var(--space-lg);
    margin-bottom: var(--space-lg);
  }

  .home-eyebrow {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-xs);
  }

  .home-title {
    margin-bottom: var(--space-xs);
  }

  .home-subtitle {
    color: var(--color-text-muted);
    font-size: 1rem;
    line-height: 1.65;
    margin: 0;
  }

  .stories-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }

  @media (min-width: 640px) {
    .stories-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .stories-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-lg);
    }

    /* First story spans full width */
    .stories-grid > :first-child {
      grid-column: 1 / -1;
    }
  }

  .empty-state {
    color: var(--color-text-muted);
    padding: var(--space-lg) 0;
  }

  .empty-cta {
    display: inline-block;
    margin-top: var(--space-sm);
    color: var(--color-accent);
    font-size: 0.9rem;
    transition: opacity var(--transition);
  }

  .empty-cta:hover {
    opacity: 0.7;
  }

  /* ---- Slideshow ---- */
  .slideshow {
    position: relative;
    width: 100%;
    height: 60vh;
    min-height: 320px;
    overflow: hidden;
    background: var(--color-bg);
    border-radius: var(--radius-md);
  }

  .slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.8s ease;
    pointer-events: none;
  }

  .slide.active {
    opacity: 1;
    pointer-events: auto;
  }

  .slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transform-origin: center center;
  }

  /* Ken Burns — different zoom origin per slide for variety */
  .slide.active img {
    animation: kb-zoom-in 6s ease-out forwards;
  }

  .slide.active:nth-child(2n) img {
    animation: kb-zoom-out 6s ease-out forwards;
    transform-origin: 70% 60%;
  }

  .slide.active:nth-child(3n) img {
    animation: kb-pan-right 6s ease-out forwards;
    transform-origin: 30% 50%;
  }

  @keyframes kb-zoom-in {
    from { transform: scale(1.08); }
    to   { transform: scale(1.0); }
  }

  @keyframes kb-zoom-out {
    from { transform: scale(1.0); }
    to   { transform: scale(1.08); }
  }

  @keyframes kb-pan-right {
    from { transform: scale(1.06) translateX(-1.5%); }
    to   { transform: scale(1.06) translateX(1.5%); }
  }

  .typewriter-overlay {
    position: absolute;
    inset: 0;
    z-index: 5;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: var(--space-md) var(--space-md) calc(var(--space-md) + 2rem);
    background: linear-gradient(to top, rgba(10, 9, 6, 0.72) 0%, transparent 60%);
    pointer-events: none;
  }

  .tw-eyebrow {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  .tw-text {
    font-family: 'Montserrat', sans-serif;
    font-weight: 600;
    letter-spacing: 0.04em;
    font-size: clamp(1.4rem, 3.5vw, 2.4rem);
    color: var(--color-text-bold);
    line-height: 1.6;
    margin: 0;
    white-space: pre-line;
  }

  #tw-target {
    background: rgba(10, 9, 6, 0.55);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    padding: 0.15em 0.5em;
    border-radius: 8px;
    box-decoration-break: clone;
    -webkit-box-decoration-break: clone;
    transition: background 0.15s;
  }

  #tw-target.tw-empty {
    background: transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    padding-inline: 0;
  }

  .tw-cursor {
    display: inline-block;
    color: var(--color-accent);
    animation: blink 0.75s step-end infinite;
    margin-left: 1px;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  @media (max-width: 639px) {
    .slide-arrow { display: none; }
  }

  .slide-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(10, 9, 6, 0.55) transparent;
    border: 2px solid var(--color-border);
    color: var(--color-text-bold);
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    font-size: 1rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background var(--transition), border-color var(--transition);
    z-index: 10;
  }

  .slide-arrow:hover {
    background: rgba(201, 168, 76, 0.18);
    border-color: var(--color-accent);
  }

  .slide-prev { left: var(--space-sm); }
  .slide-next { right: var(--space-sm); }

  @media (max-width: 639px) {
    .slide-arrow { display: none; }
  }

  .slide-dots {
    position: absolute;
    bottom: var(--space-sm);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0.5rem;
    z-index: 10;
  }

  .slide-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    border: none;
    background: rgba(255, 245, 220, 0.35);
    cursor: pointer;
    padding: 0;
    transition: background var(--transition), transform var(--transition);
  }

  .slide-dot.active {
    background: var(--color-accent);
    transform: scale(1.4);
  }
</style>

<script is:inline define:vars={{ slides }}>
  // --- Slideshow ---
  const slideEls = document.querySelectorAll('.slide');
  const dots = document.querySelectorAll('.slide-dot');
  let current = 0;

  function goTo(index) {
    slideEls[current].classList.remove('active');
    dots[current].classList.remove('active');
    current = (index + slideEls.length) % slideEls.length;
    slideEls[current].classList.add('active');
    dots[current].classList.add('active');
    typePhrase(slides[current].text);
  }

  document.querySelector('.slide-next')?.addEventListener('click', () => goTo(current + 1));
  document.querySelector('.slide-prev')?.addEventListener('click', () => goTo(current - 1));
  dots.forEach(dot => dot.addEventListener('click', () => goTo(Number(dot.dataset.dot))));

  // --- Touch swipe ---
  const slideshowEl = document.getElementById('slideshow');
  let touchStartX = 0;
  slideshowEl.addEventListener('touchstart', e => { touchStartX = e.touches[0].clientX; }, { passive: true });
  slideshowEl.addEventListener('touchend', e => {
    const diff = touchStartX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 40) goTo(current + (diff > 0 ? 1 : -1));
  }, { passive: true });

  // --- Typewriter ---
  const target = document.getElementById('tw-target');

  const TYPE_SPEED = 25;
  const ERASE_SPEED = 10;
  const PAUSE_AFTER_TYPE = 2200;

  const PAUSE_AFTER_ERASE = 400;

  let generation = 0;

  function sleep(ms) {
    return new Promise(resolve => setTimeout(resolve, ms));
  }

  function setText(text) {
    target.textContent = text;
    target.classList.toggle('tw-empty', text.replace(/\n/g, '') === '');
  }

  async function typePhrase(phrase) {
    const gen = ++generation;

    // Erase whatever is currently shown — all lines in parallel
    const current_lines = (target.textContent ?? '').split('\n');
    const currentMax = Math.max(...current_lines.map(l => l.length));
    for (let i = currentMax; i >= 0; i--) {
      if (generation !== gen) return;
      setText(current_lines.map(l => l.slice(0, i)).join('\n'));
      await sleep(ERASE_SPEED);
    }

    await sleep(PAUSE_AFTER_ERASE);
    if (generation !== gen) return;

    // Type the new phrase — all lines in parallel
    const lines = phrase.split('\n');
    const maxLen = Math.max(...lines.map(l => l.length));
    for (let i = 0; i <= maxLen; i++) {
      if (generation !== gen) return;
      setText(lines.map(l => l.slice(0, i)).join('\n'));
      await sleep(TYPE_SPEED);
    }

    await sleep(PAUSE_AFTER_TYPE);
    if (generation !== gen) return;

    // Erase and loop back to first slide's text via slide advance
    // for (let i = phrase.length; i >= 0; i--) {
    //   if (generation !== gen) return;
    //   target.textContent = phrase.slice(0, i);
    //   await sleep(ERASE_SPEED);
    // }

    await sleep(PAUSE_AFTER_ERASE);
  }

  // Start with the first slide's text
  typePhrase(slides[0].text);
</script>
