---
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';
import StoryCard from '../components/StoryCard.astro';
import Slideshow from '../components/Slideshow.astro';

const stories = (await getCollection('stories', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<PageLayout
  title="Vibrum | Handcrafted guitars"
  description="Handcrafted guitars made by Vibrum, where traditional craftsmanship meets design. We are dedicated to creating unique, high-quality instruments that inspire musicians worldwide."
>
  <div class="container section">
    <Slideshow />

    <header class="home-header">
      <p class="home-eyebrow">stories</p>
      <!-- <h1 class="home-title">Check out our latest stories</h1> -->
      <!-- <p class="home-subtitle">
        Each build has a story. Follow the work.
      </p> -->
    </header>

    <div class="stories-section">
      <div class="ghost-mark" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 320 320" aria-hidden="true" focusable="false">
          <path d="m157,41v111.958c0,.179-.095.344-.25.433l-96.939,55.98c-.443.256-.939-.24-.683-.683L156.067,40.75c.256-.443.933-.262.933.25Z"/>
          <path d="m163,152.958V40.999c0-.512.677-.693.933-.25l96.939,167.938c.256.443-.24.939-.683.683l-96.939-55.98c-.155-.089-.25-.254-.25-.433Z"/>
          <path d="m62.809,214.567l96.941-55.98c.155-.089.345-.089.5,0l96.94,55.98c.443.256.261.933-.25.933H63.059c-.512,0-.693-.677-.25-.933Z"/>
        </svg>
      </div>

      {stories.length > 0 ? (
        <div class="stories-grid">
          {stories.map(story => (
            <StoryCard
              title={story.data.title}
              slug={story.slug}
              date={story.data.date}
              coverImage={story.data.coverImage}
              excerpt={story.data.excerpt}
              tags={story.data.tags}
            />
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <p>Stories coming soon. Check back after the first build.</p>
          <a href="/gallery" class="empty-cta">Browse the gallery →</a>
        </div>
      )}
    </div>
  </div>
</PageLayout>

<style>
  /* Ghost mark */
  .stories-section {
    position: relative;
    overflow: hidden;
  }

  .ghost-mark {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 480px;
    height: 480px;
    pointer-events: none;
    z-index: 0;
  }

  .ghost-mark svg {
    width: 100%;
    height: 100%;
    fill: var(--color-accent);
    opacity: 0.05;
    filter: blur(1px);
    animation: ghost-rotate 120s linear infinite;
  }

  @keyframes ghost-rotate {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  .stories-grid, .empty-state {
    position: relative;
    z-index: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .ghost-mark svg { animation: none; }
  }

  /* Page content */
  .home-header {
    margin-top: var(--space-lg);
    margin-bottom: var(--space-lg);
  }

  .home-eyebrow {
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin-bottom: var(--space-xs);

    /* Center with decorative lines */
    display: flex;
    align-items: center;
    gap: 2.5rem;
    text-align: center;
    white-space: nowrap;

    /* Shimmer sweep across text */
    background: linear-gradient(
      90deg,
      #c9a84c 30%,
      #fff3c4 47%,
      #fffbe8 50%,
      #fff3c4 53%,
      #c9a84c 70%
    );
    background-size: 400% auto;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: eyebrow-gloss 6s ease-in-out infinite alternate;
  }

  .home-eyebrow::before,
  .home-eyebrow::after {
    content: '';
    flex: 1;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      #c9a84c 30%,
      #fff3c4 47%,
      #fffbe8 50%,
      #fff3c4 53%,
      #c9a84c 70%,
      transparent 100%
    );
    background-size: 400% auto;
    animation: eyebrow-gloss 6s ease-in-out infinite alternate;
    opacity: 0.6;
  }

  @keyframes eyebrow-gloss {
    0%   { background-position: 120% center; }
    100% { background-position: -20% center; }
  }

  @media (prefers-reduced-motion: reduce) {
    .home-eyebrow,
    .home-eyebrow::before,
    .home-eyebrow::after {
      animation: none;
      background-position: 0% center;
    }
  }

  .home-title {
    margin-bottom: var(--space-xs);
  }

  .stories-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }

  @media (max-width: 639px) {
    .home-eyebrow {
      gap: 1.5rem;
      font-size: 0.70rem;
    }

    .stories-grid {
      padding-inline: var(--space-sm);
    }

    .home-header {
      padding-inline: calc(var(--space-sm) + 0.5rem);
    }
  }

  @media (min-width: 640px) {
    .stories-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .stories-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-lg);
    }

    .stories-grid > :first-child {
      grid-column: 1 / -1;
    }
  }

  .empty-state {
    color: var(--color-text-muted);
    padding: var(--space-lg) 0;
  }

  .empty-cta {
    display: inline-block;
    margin-top: var(--space-sm);
    color: var(--color-accent);
    font-size: 0.9rem;
    transition: opacity var(--transition);
  }

  .empty-cta:hover {
    opacity: 0.7;
  }
</style>

