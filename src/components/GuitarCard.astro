---
interface Props {
  title: string;
  slug: string;
  year: number;
  status: string;
  coverImage: string;
  excerpt: string;
}

const { title, slug, year, status, coverImage, excerpt } = Astro.props;

const statusLabels: Record<string, string> = {
  available: 'Available',
  sold: 'Sold',
  'in-progress': 'In Progress',
  commission: 'Commission',
};
---

<a href={`/gallery/${slug}`} class="guitar-card">
  <div class="guitar-card-image">
    <img src={coverImage} alt={title} loading="lazy" />
    {status !== 'available' && (
      <span class:list={['guitar-card-status', `guitar-card-status--${status}`]}>
        {statusLabels[status]}
      </span>
    )}
  </div>
  <div class="guitar-card-body">
    <h3 class="guitar-card-title">{title}</h3>
    <p class="guitar-card-meta">{year}</p>
    <p class="guitar-card-excerpt">{excerpt}</p>
  </div>
</a>

<style>
  .guitar-card {
    display: block;
    background-color: var(--color-bg-raised);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: border-color var(--transition), background-color var(--transition);
  }

  .guitar-card:hover {
    border-color: rgba(201, 168, 76, 0.35);
    background-color: var(--color-bg-surface);
  }

  .guitar-card:hover .guitar-card-image img {
    transform: scale(1.03);
  }

  .guitar-card-image {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background-color: var(--color-bg-surface);
  }

  .guitar-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 350ms ease;
  }

  .guitar-card-status {
    position: absolute;
    top: var(--space-xs);
    right: var(--space-xs);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: var(--radius-sm);
    background-color: var(--color-bg);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
  }

  .guitar-card-status--sold {
    color: rgba(255, 245, 220, 0.6);
  }

  .guitar-card-status--in-progress {
    color: var(--color-accent);
    border-color: rgba(201, 168, 76, 0.4);
  }

  .guitar-card-body {
    padding: var(--space-sm);
  }

  .guitar-card-title {
    font-size: 1.1rem;
    font-family: var(--font-heading);
    color: var(--color-text-bold);
    margin-bottom: 2px;
  }

  .guitar-card-meta {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    letter-spacing: 0.08em;
    margin-bottom: var(--space-xs);
  }

  .guitar-card-excerpt {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin: 0;

    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
