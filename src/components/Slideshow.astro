---
import { getCollection } from 'astro:content';
const slideEntries = (await getCollection('slides')).sort((a, b) => a.id.localeCompare(b.id));
const slides = slideEntries.map(e => e.data);
---

<div class="slideshow" id="slideshow" aria-label="Workshop slideshow">
  {slides.map((slide, i) => (
    <div class={`slide${i === 0 ? ' active' : ''}`} data-index={i}>
      <img src={slide.src} alt="" loading={i === 0 ? 'eager' : 'lazy'} />
    </div>
  ))}

  <div class="typewriter-overlay">
    <div class="tw-row">
      <p class="tw-text"><span id="tw-target"></span></p>
      <a id="slide-btn" class="slide-btn" href="#"></a>
    </div>
  </div>
  <button class="slide-arrow slide-prev" aria-label="Previous slide">&#8592;</button>
  <button class="slide-arrow slide-next" aria-label="Next slide">&#8594;</button>
  <div class="slide-dots" id="slide-dots">
    {slides.map((_, i) => (
      <button class={`slide-dot${i === 0 ? ' active' : ''}`} data-dot={i} aria-label={`Go to slide ${i + 1}`}></button>
    ))}
  </div>
</div>

<style is:global>
  /* ---- Slideshow ---- */
  .slideshow {
    position: relative;
    width: 100%;
    height: 60vh;
    min-height: 320px;
    overflow: hidden;
    background: var(--color-bg);
    border-radius: var(--radius-md);
  }

  .slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.8s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
  }

  .slide.active {
    opacity: 1;
    pointer-events: auto;
  }

  /* Ken Burns — always applied, paused when not active so the transform is
     held at the `from` state and never snaps to scale(1) during fade-out. */
  .slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transform-origin: 60% 50%;
    animation-name: kb-zoom-in;
    animation-duration: 8s;
    animation-timing-function: cubic-bezier(0.25, 0.46, 0.45, 0.94);
    animation-fill-mode: both;
    animation-play-state: paused;
  }

  .slide:nth-child(2n) img {
    animation-name: kb-zoom-out;
    transform-origin: 40% 60%;
  }

  .slide:nth-child(3n) img {
    animation-name: kb-pan-right;
    transform-origin: 30% 50%;
  }

  .slide:nth-child(4n) img {
    animation-name: kb-pan-left;
    transform-origin: 70% 50%;
  }

  .slide.active img {
    animation-play-state: running;
  }

  @keyframes kb-zoom-in {
    from { transform: scale(1.08) translateX(0); }
    to   { transform: scale(1.14) translateX(-1.5%); }
  }

  @keyframes kb-zoom-out {
    from { transform: scale(1.12) translateX(0); }
    to   { transform: scale(1.06) translateX(1%); }
  }

  @keyframes kb-pan-right {
    from { transform: scale(1.1) translateX(-1%); }
    to   { transform: scale(1.1) translateX(1%); }
  }

  @keyframes kb-pan-left {
    from { transform: scale(1.1) translateX(1%); }
    to   { transform: scale(1.1) translateX(-1%); }
  }

  .typewriter-overlay {
    position: absolute;
    inset: 0;
    z-index: 5;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: var(--space-md) var(--space-md) calc(var(--space-md) + 2rem);
    background: linear-gradient(to top, rgba(10, 9, 6, 0.72) 0%, transparent 60%);
    pointer-events: none;
  }

  .tw-row {
    display: flex;
    align-items: flex-end;
    gap: var(--space-sm);
  }

  .tw-text {
    flex: 1;
    font-family: 'Montserrat', sans-serif;
    font-weight: 600;
    letter-spacing: 0.04em;
    font-size: clamp(1.4rem, 3.5vw, 2.4rem);
    color: var(--color-text-bold);
    line-height: 1.6;
    margin: 0;
  }

  .slide-btn {
    flex-shrink: 0;
    display: inline-block;
    background-color: var(--color-accent);
    color: #0a0906;
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    padding: 10px 20px;
    margin-right: 50px;
    border-radius: var(--radius-md);
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.20s ease;
  }

  .slide-btn.visible {
    opacity: 0.7;
    pointer-events: auto;
  }

  .slide-btn:hover {
    opacity: 0.88;
  }

  .slide-btn.visible:hover {
    opacity: 0.88;
    /* transform: scale(1.05); */
    /* border: #0a0906 2px solid; */
  }

  #tw-target.tw-empty .tw-line {
    background: transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    padding-inline: 0;
  }

  .tw-line {
    background: rgba(10, 9, 6, 0.55);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    padding: 0.15em 0.5em;
    border-radius: 8px;
    box-decoration-break: clone;
    -webkit-box-decoration-break: clone;
    transition: background 0.15s;
  }

  @media (max-width: 639px) {
    .slide-arrow { display: none; }

    .tw-text {
      position: absolute;
      top: var(--space-md);
      left: var(--space-md);
      right: var(--space-md);
      font-size: clamp(1.2rem, 3.5vw, 2.2rem);
      flex: none;
    }

    .slide-btn {
      margin-left: auto;
      margin-right: 0;
    }
  }

  .slide-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(10, 9, 6, 0.35);
    border: 2px solid var(--color-border);
    color: var(--color-text-bold);
    width: clamp(2rem, 4vw, 2.5rem);
    height: clamp(2rem, 4vw, 2.5rem);
    border-radius: 50%;
    font-size: clamp(0.8rem, 1.5vw, 1.1rem);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: background var(--transition), border-color var(--transition), opacity var(--transition), transform var(--transition);
    z-index: 10;
  }

  .slideshow:hover .slide-arrow {
    opacity: 1;
  }

  .slide-arrow:hover {
    background: rgba(201, 168, 76, 0.18);
    border-color: var(--color-accent);
  }

  .slide-prev { left: var(--space-sm); }
  .slide-next { right: var(--space-sm); }

  .slide-prev:hover { transform: translateY(-50%) translateX(-2px); }
  .slide-next:hover { transform: translateY(-50%) translateX(2px); }

  .slide-dots {
    position: absolute;
    bottom: var(--space-sm);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0.6rem;
    z-index: 10;
  }

  .slide-dot {
    width: 6px;
    height: 6px;
    opacity: 0.7;
    border-radius: 3px;
    border: none;
    background: rgba(255, 245, 220, 0.35);
    cursor: pointer;
    padding: 0;
    transition: background var(--transition), width 0.3s ease, border-radius 0.3s ease;
  }

  .slide-dot.active {
    background: var(--color-accent);
    transform: scale(1.35);
    opacity: 0.7;
    /* width: 20px; */
    /* border-radius: 3px; */
  }
</style>

<script is:inline define:vars={{ slides }}>
  // --- Slideshow ---
  const slideEls = document.querySelectorAll('.slide');
  const dots = document.querySelectorAll('.slide-dot');
  let current = 0;

  function goTo(index) {
    slideEls[current].classList.remove('active'); // animation pauses in place, no snap
    dots[current].classList.remove('active');
    current = (index + slideEls.length) % slideEls.length;
    // Reset KB animation so it always starts from frame 0 on the incoming slide.
    const inImg = slideEls[current].querySelector('img');
    if (inImg) {
      inImg.style.animationName = 'none';
      void inImg.offsetWidth; // force reflow to flush the reset
      inImg.style.animationName = '';
    }
    slideEls[current].classList.add('active');
    dots[current].classList.add('active');
    hideButton();
    typePhrase(slides[current].text, slides[current].button);
  }

  document.querySelector('.slide-next')?.addEventListener('click', () => goTo(current + 1));
  document.querySelector('.slide-prev')?.addEventListener('click', () => goTo(current - 1));
  dots.forEach(dot => dot.addEventListener('click', () => goTo(Number(dot.dataset.dot))));

  // --- Touch & mouse swipe ---
  const slideshowEl = document.getElementById('slideshow');
  let dragStartX = 0;
  let dragging = false;

  slideshowEl.addEventListener('touchstart', e => { dragStartX = e.touches[0].clientX; }, { passive: true });
  slideshowEl.addEventListener('touchend', e => {
    const diff = dragStartX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 40) goTo(current + (diff > 0 ? 1 : -1));
  }, { passive: true });

  slideshowEl.addEventListener('mousedown', e => { dragStartX = e.clientX; dragging = true; });
  slideshowEl.addEventListener('mousemove', e => { if (dragging) e.preventDefault(); });
  slideshowEl.addEventListener('mouseup', e => {
    if (!dragging) return;
    dragging = false;
    const diff = dragStartX - e.clientX;
    if (Math.abs(diff) > 40) goTo(current + (diff > 0 ? 1 : -1));
  });
  slideshowEl.addEventListener('mouseleave', () => { dragging = false; });

  // --- Slide button ---
  const slideBtn = document.getElementById('slide-btn');

  function showButton(btn) {
    if (btn) {
      slideBtn.textContent = btn.label;
      slideBtn.href = btn.url;
      slideBtn.classList.add('visible');
    } else {
      slideBtn.classList.remove('visible');
    }
  }

  function hideButton() {
    slideBtn.classList.remove('visible');
  }

  // --- Typewriter ---
  const target = document.getElementById('tw-target');

  const TYPE_SPEED = 20;
  const ERASE_SPEED = 10;
  const PAUSE_AFTER_TYPE = 2200;
  const PAUSE_AFTER_ERASE = 400;
  const BUTTON_FADE = 200; // ms — matches .slide-btn CSS transition

  let generation = 0;

  function sleep(ms) {
    return new Promise(resolve => setTimeout(resolve, ms));
  }

  function setText(text) {
    const lines = text.split('\n');
    target.innerHTML = lines
      .map(line => `<span class="tw-line">${line}</span>`)
      .join('<br>');
    target.classList.toggle('tw-empty', text.replace(/\n/g, '') === '');
  }

  async function typePhrase(phrase, button) {
    const gen = ++generation;

    // Erase whatever is currently shown — all lines in parallel
    const current_lines = Array.from(target.querySelectorAll('.tw-line')).map(s => s.textContent ?? '');
    if (current_lines.length === 0) current_lines.push('');
    const currentMax = Math.max(...current_lines.map(l => l.length));
    for (let i = currentMax; i >= 0; i--) {
      if (generation !== gen) return;
      setText(current_lines.map(l => l.slice(0, i)).join('\n'));
      await sleep(ERASE_SPEED);
    }

    await sleep(PAUSE_AFTER_ERASE);
    if (generation !== gen) return;

    // Type the new phrase — all lines in parallel
    const lines = phrase.split('\n');
    const maxLen = Math.max(...lines.map(l => l.length));
    const fadeStartAt = maxLen - Math.ceil(BUTTON_FADE / TYPE_SPEED);
    for (let i = 0; i <= maxLen; i++) {
      if (generation !== gen) return;
      setText(lines.map(l => l.slice(0, i)).join('\n'));
      if (button && i >= fadeStartAt) showButton(button);
      await sleep(TYPE_SPEED);
    }

    await sleep(PAUSE_AFTER_TYPE);
  }

  // Start with the first slide's text
  typePhrase(slides[0].text, slides[0].button);
</script>
