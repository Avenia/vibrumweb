---
import { getCollection } from 'astro:content';
const slideEntries = (await getCollection('slides')).sort((a, b) => a.id.localeCompare(b.id));
const slides = slideEntries.map(e => e.data);
---

<div class="slideshow" id="slideshow" aria-label="Workshop slideshow">
  {slides.map((slide, i) => (
    <div class={`slide${i === 0 ? ' active' : ''}`} data-index={i}>
      <img src={slide.src} alt="" loading={i === 0 ? 'eager' : 'lazy'} />
    </div>
  ))}

  <div class="typewriter-overlay">
    <p class="tw-text"><span id="tw-target"></span></p>
  </div>
  <button class="slide-arrow slide-prev" aria-label="Previous slide">&#8592;</button>
  <button class="slide-arrow slide-next" aria-label="Next slide">&#8594;</button>
  <div class="slide-dots" id="slide-dots">
    {slides.map((_, i) => (
      <button class={`slide-dot${i === 0 ? ' active' : ''}`} data-dot={i} aria-label={`Go to slide ${i + 1}`}></button>
    ))}
  </div>
</div>

<style is:global>
  /* ---- Slideshow ---- */
  .slideshow {
    position: relative;
    width: 100%;
    height: 60vh;
    min-height: 320px;
    overflow: hidden;
    background: var(--color-bg);
    border-radius: var(--radius-md);
  }

  .slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
  }

  .slide.active {
    opacity: 1;
    pointer-events: auto;
  }

  .slide img {
    animation: none;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transform-origin: center center;
  }

  /* Ken Burns — fill-mode: both holds the `from` state during the fade-in */
  .slide.active img {
    animation: kb-zoom-in 6s ease-out both;
  }

  .slide.active:nth-child(2n) img {
    animation: kb-zoom-out 6s ease-out both;
    transform-origin: 70% 60%;
  }

  .slide.active:nth-child(3n) img {
    animation: kb-pan-right 6s ease-out both;
    transform-origin: 30% 50%;
  }

  @keyframes kb-zoom-in {
    from { transform: scale(1.0); }
    to   { transform: scale(1.08); }
  }

  @keyframes kb-zoom-out {
    from { transform: scale(1.0); }
    to   { transform: scale(1.06); }
  }

  @keyframes kb-pan-right {
    from { transform: scale(1.0) translateX(0%); }
    to   { transform: scale(1.0) translateX(1.5%); }
  }

  .typewriter-overlay {
    position: absolute;
    inset: 0;
    z-index: 5;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: var(--space-md) var(--space-md) calc(var(--space-md) + 2rem);
    background: linear-gradient(to top, rgba(10, 9, 6, 0.72) 0%, transparent 60%);
    pointer-events: none;
  }

  .tw-text {
    font-family: 'Montserrat', sans-serif;
    font-weight: 600;
    letter-spacing: 0.04em;
    font-size: clamp(1.4rem, 3.5vw, 2.4rem);
    color: var(--color-text-bold);
    line-height: 1.6;
    margin: 0;
    white-space: pre-line;
  }

  #tw-target {
    background: rgba(10, 9, 6, 0.55);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    padding: 0.15em 0.5em;
    border-radius: 8px;
    box-decoration-break: clone;
    -webkit-box-decoration-break: clone;
    transition: background 0.15s;
  }

  #tw-target.tw-empty {
    background: transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    padding-inline: 0;
  }

  @media (max-width: 639px) {
    .slide-arrow { display: none; }
  }

  .slide-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(10, 9, 6, 0.35);
    border: 2px solid var(--color-border);
    color: var(--color-text-bold);
    width: clamp(2rem, 4vw, 2.5rem);
    height: clamp(2rem, 4vw, 2.5rem);
    border-radius: 50%;
    font-size: clamp(0.8rem, 1.5vw, 1.1rem);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: background var(--transition), border-color var(--transition), opacity var(--transition);
    z-index: 10;
  }

  .slideshow:hover .slide-arrow {
    opacity: 1;
  }

  .slide-arrow:hover {
    background: rgba(201, 168, 76, 0.18);
    border-color: var(--color-accent);
  }

  .slide-prev { left: var(--space-sm); }
  .slide-next { right: var(--space-sm); }

  .slide-dots {
    position: absolute;
    bottom: var(--space-sm);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0.6rem;
    z-index: 10;
  }

  .slide-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    border: none;
    background: rgba(255, 245, 220, 0.35);
    cursor: pointer;
    padding: 0;
    transition: background var(--transition), transform var(--transition);
  }

  .slide-dot.active {
    background: var(--color-accent);
    transform: scale(1.4);
  }
</style>

<script is:inline define:vars={{ slides }}>
  // --- Slideshow ---
  const slideEls = document.querySelectorAll('.slide');
  const dots = document.querySelectorAll('.slide-dot');
  let current = 0;

  function goTo(index) {
    slideEls[current].classList.remove('active');
    dots[current].classList.remove('active');
    current = (index + slideEls.length) % slideEls.length;
    slideEls[current].classList.add('active');
    dots[current].classList.add('active');
    typePhrase(slides[current].text);
  }

  document.querySelector('.slide-next')?.addEventListener('click', () => goTo(current + 1));
  document.querySelector('.slide-prev')?.addEventListener('click', () => goTo(current - 1));
  dots.forEach(dot => dot.addEventListener('click', () => goTo(Number(dot.dataset.dot))));

  // --- Touch & mouse swipe ---
  const slideshowEl = document.getElementById('slideshow');
  let dragStartX = 0;
  let dragging = false;

  slideshowEl.addEventListener('touchstart', e => { dragStartX = e.touches[0].clientX; }, { passive: true });
  slideshowEl.addEventListener('touchend', e => {
    const diff = dragStartX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 40) goTo(current + (diff > 0 ? 1 : -1));
  }, { passive: true });

  slideshowEl.addEventListener('mousedown', e => { dragStartX = e.clientX; dragging = true; });
  slideshowEl.addEventListener('mousemove', e => { if (dragging) e.preventDefault(); });
  slideshowEl.addEventListener('mouseup', e => {
    if (!dragging) return;
    dragging = false;
    const diff = dragStartX - e.clientX;
    if (Math.abs(diff) > 40) goTo(current + (diff > 0 ? 1 : -1));
  });
  slideshowEl.addEventListener('mouseleave', () => { dragging = false; });

  // --- Typewriter ---
  const target = document.getElementById('tw-target');

  const TYPE_SPEED = 25;
  const ERASE_SPEED = 10;
  const PAUSE_AFTER_TYPE = 2200;
  const PAUSE_AFTER_ERASE = 400;

  let generation = 0;

  function sleep(ms) {
    return new Promise(resolve => setTimeout(resolve, ms));
  }

  function setText(text) {
    target.textContent = text;
    target.classList.toggle('tw-empty', text.replace(/\n/g, '') === '');
  }

  async function typePhrase(phrase) {
    const gen = ++generation;

    // Erase whatever is currently shown — all lines in parallel
    const current_lines = (target.textContent ?? '').split('\n');
    const currentMax = Math.max(...current_lines.map(l => l.length));
    for (let i = currentMax; i >= 0; i--) {
      if (generation !== gen) return;
      setText(current_lines.map(l => l.slice(0, i)).join('\n'));
      await sleep(ERASE_SPEED);
    }

    await sleep(PAUSE_AFTER_ERASE);
    if (generation !== gen) return;

    // Type the new phrase — all lines in parallel
    const lines = phrase.split('\n');
    const maxLen = Math.max(...lines.map(l => l.length));
    for (let i = 0; i <= maxLen; i++) {
      if (generation !== gen) return;
      setText(lines.map(l => l.slice(0, i)).join('\n'));
      await sleep(TYPE_SPEED);
    }

    await sleep(PAUSE_AFTER_TYPE);
  }

  // Start with the first slide's text
  typePhrase(slides[0].text);
</script>
